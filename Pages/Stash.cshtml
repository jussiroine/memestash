@page "/{slug}"
@model MemeStash.Pages.StashModel
@{
    ViewData["Title"] = $"{Model.Slug}'s Stash";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🗂️ <strong>@Model.Slug</strong>'s Stash</h2>
    <span class="badge bg-secondary">@Model.Memes.Count meme@(Model.Memes.Count == 1 ? "" : "s")</span>
</div>

<!-- Usage Stats -->
@{
    var countPct = Model.MaxMemes > 0 ? (int)(100.0 * Model.Stats.MemeCount / Model.MaxMemes) : 0;
    var sizePct = Model.MaxStorageBytes > 0 ? (int)(100.0 * Model.Stats.TotalSizeBytes / Model.MaxStorageBytes) : 0;
    var barColor = Math.Max(countPct, sizePct) >= 90 ? "bg-danger" : Math.Max(countPct, sizePct) >= 70 ? "bg-warning" : "bg-success";
}
<div class="card mb-4">
    <div class="card-body py-2 px-3">
        <div class="row small text-muted">
            <div class="col-md-6 mb-1">
                <span>Memes: @Model.Stats.MemeCount / @Model.MaxMemes</span>
                <div class="progress" style="height: 6px;">
                    <div class="progress-bar @barColor" style="width: @(countPct)%"></div>
                </div>
            </div>
            <div class="col-md-6 mb-1">
                <span>Storage: @Model.Stats.TotalSizeFormatted / @(Model.MaxStorageBytes / (1024 * 1024)) MB</span>
                <div class="progress" style="height: 6px;">
                    <div class="progress-bar @barColor" style="width: @(sizePct)%"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Upload Area -->
<div id="drop-zone" class="drop-zone mb-4">
    <form id="upload-form" method="post" enctype="multipart/form-data" action="/api/memes/@Model.Slug">
        <div class="drop-zone-content text-center p-4">
            <p class="mb-2 fs-5">📤 Drag &amp; drop memes here, or click to browse</p>
            <p class="text-muted small mb-3">JPG, PNG, GIF, WebP &mdash; up to 5 MB</p>
            <input type="file" id="file-input" name="file" accept=".jpg,.jpeg,.png,.gif,.webp"
                   class="d-none" multiple />
            <button type="button" id="browse-btn" class="btn btn-outline-primary">Browse files</button>
        </div>
        <div id="upload-progress" class="d-none">
            <div class="progress">
                <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%"></div>
            </div>
            <p class="text-center mt-2 small text-muted" id="upload-status">Uploading...</p>
        </div>
    </form>
</div>

<!-- Sort Controls -->
<div class="d-flex justify-content-end mb-3">
    <div class="btn-group btn-group-sm" role="group" aria-label="Sort memes">
        <a asp-page="/Stash" asp-route-slug="@Model.Slug" asp-route-sort="newest"
           class="btn @(Model.Sort == "newest" ? "btn-primary" : "btn-outline-primary")">Newest</a>
        <a asp-page="/Stash" asp-route-slug="@Model.Slug" asp-route-sort="oldest"
           class="btn @(Model.Sort == "oldest" ? "btn-primary" : "btn-outline-primary")">Oldest</a>
        <a asp-page="/Stash" asp-route-slug="@Model.Slug" asp-route-sort="largest"
           class="btn @(Model.Sort == "largest" ? "btn-primary" : "btn-outline-primary")">Largest</a>
        <a asp-page="/Stash" asp-route-slug="@Model.Slug" asp-route-sort="smallest"
           class="btn @(Model.Sort == "smallest" ? "btn-primary" : "btn-outline-primary")">Smallest</a>
    </div>
</div>

<!-- Meme Gallery -->
@if (Model.Memes.Count == 0)
{
    <div class="text-center text-muted py-5">
        <p class="fs-4">No memes yet!</p>
        <p>Upload your first meme to get started.</p>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3" id="meme-gallery">
        @foreach (var meme in Model.Memes)
        {
            <div class="col" data-blob="@meme.BlobName" data-pinned="@meme.IsPinned.ToString().ToLower()">
                <div class="card h-100 meme-card @(meme.IsPinned ? "border-warning" : "")">
                    @if (meme.IsPinned)
                    {
                        <span class="pinned-badge">📌</span>
                    }
                    <img src="@meme.Url" class="card-img-top meme-img" alt="@(meme.OriginalFileName ?? meme.BlobName)"
                         loading="lazy" />
                    <div class="card-body p-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted text-truncate" title="@meme.OriginalFileName">
                                @(meme.OriginalFileName ?? meme.BlobName)
                            </small>
                            <div class="btn-group btn-group-sm">
                                <button class="btn @(meme.IsPinned ? "btn-warning" : "btn-outline-warning") btn-pin"
                                        data-slug="@Model.Slug" data-blob="@meme.BlobName"
                                        data-pinned="@meme.IsPinned.ToString().ToLower()"
                                        title="@(meme.IsPinned ? "Unpin" : "Pin")">📌</button>
                                <button class="btn btn-outline-primary btn-copy-img"
                                        data-url="@meme.Url" title="Copy image">🖼️</button>
                                <button class="btn btn-outline-secondary btn-copy"
                                        data-url="@meme.Url" title="Copy link">📋</button>
                                <button class="btn btn-outline-danger btn-delete"
                                        data-slug="@Model.Slug" data-blob="@meme.BlobName" title="Delete">🗑️</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script src="~/js/upload.js" asp-append-version="true"></script>
}
